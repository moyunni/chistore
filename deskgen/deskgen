#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$HOME/.local/share/applications"
mkdir -p "$APP_DIR"

# Defaults
CMD=""
TARGET=""
INTERACTIVE=false
LANG_MODE="en"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        new|start) CMD="new"; shift; TARGET="${1:-}" ;;
        ls|-ls) CMD="ls"; shift ;;
        rm|delete) CMD="rm"; shift; TARGET="${1:-}" ;;
        edit|nano) CMD="edit"; shift; TARGET="${1:-}" ;;
        help|-h|--help) CMD="help"; shift ;;
        -i|--interactive) INTERACTIVE=true; shift ;;
        --lang) LANG_MODE="$2"; shift 2 ;;
        *) TARGET="${1:-}"; shift ;;
    esac
done

# Ensure .desktop extension
add_ext() { [[ "$1" == *.desktop ]] && echo "$1" || echo "$1.desktop"; }

# Language maps for comments
declare -A CMT_EN=(
    [name]="Application name (required)"
    [generic]="Short generic name (optional)"
    [comment]="Longer description (optional)"
    [exec]="Command to execute. %f=file, %u=url, %F/%U=list (required)"
    [icon]="Absolute path or icon name from theme"
    [terminal]="Run in terminal? true/false"
    [type]="Application, Link, or Directory"
    [categories]="Semicolon-separated. e.g., Utility;Development;"
    [keywords]="Search keywords. e.g., tool;app;cli;"
    [startup_notify]="Show startup notification? true/false"
    [mimetype]="Handled MIME types. e.g., text/plain;application/pdf;"
    [url]="URL for Type=Link"
    [pref_lang]="Preferred language codes. e.g., en;ru;"
)

declare -A CMT_RU=(
    [name]="Название приложения (обязательно)"
    [generic]="Короткое общее название (опционально)"
    [comment]="Подробное описание (опzionale)"
    [exec]="Команда запуска. %f=файл, %u=ссылка, %F/%U=список (обязательно)"
    [icon]="Путь до иконки или имя из темы иконок"
    [terminal]="Запускать в терминале? true/false"
    [type]="Application, Link или Directory"
    [categories]="Категории через точку с запятой. Пример: Utility;Development;"
    [keywords]="Ключевые слова для поиска. Пример: tool;app;cli;"
    [startup_notify]="Показывать уведомление о запуске? true/false"
    [mimetype]="Поддерживаемые MIME-типы. Пример: text/plain;application/pdf;"
    [url]="Ссылка для Type=Link"
    [pref_lang]="Предпочитаемые языки. Пример: en;ru;"
)

CMT=()
if [[ "$LANG_MODE" == "ru" ]]; then CMT=("${CMT_RU[@]}"); else CMT=("${CMT_EN[@]}"); fi

generate_template() {
    local file="$1" name="$2" exec_cmd="$3" icon="$4" term="$5" comment="$6"
    cat > "$file" <<EOF
[Desktop Entry]
# ${CMT[name]}
Name=${name:-New Application}

# ${CMT[generic]}
# GenericName=

# ${CMT[comment]}
Comment=${comment:-A brief description of the application}

# ${CMT[exec]}
Exec=${exec_cmd:-/path/to/executable %f}

# ${CMT[icon]}
Icon=${icon:-application-x-executable}

# ${CMT[terminal]}
Terminal=${term:-false}

# ${CMT[type]}
Type=Application

# ==========================================
# ADVANCED / REFERENCE FIELDS (Commented)
# ==========================================
# ${CMT[categories]}
# Categories=

# ${CMT[keywords]}
# Keywords=

# ${CMT[startup_notify]}
# StartupNotify=false

# ${CMT[mimetype]}
# MimeType=

# ${CMT[url]} (Use if Type=Link)
# URL=

# ${CMT[pref_lang]}
# PrefersNonDefaultGPU=false
EOF
    echo "[OK] Created: $file"
}

interactive_wizard() {
    local file="$1"
    local prompt_name="Application Name"
    local prompt_exec="Executable Command (e.g., /usr/bin/kitty)"
    local prompt_icon="Icon Path/Name (press Enter for default)"
    local prompt_term="Run in Terminal? (y/n)"
    local prompt_comment="Description (press Enter for default)"

    if [[ "$LANG_MODE" == "ru" ]]; then
        prompt_name="Название приложения"
        prompt_exec="Путь до исполняемого файла (например, /usr/bin/kitty)"
        prompt_icon="Путь до иконки (Enter для стандартной)"
        prompt_term="Запускать в терминале? (y/n)"
        prompt_comment="Описание (Enter для стандартного)"
    fi

    echo -e "\n${C_YELLOW}🖥️  Interactive Desktop File Generator${C_RESET}\n"
    read -rp "$prompt_name: " in_name
    read -rp "$prompt_exec: " in_exec
    read -rp "$prompt_icon: " in_icon
    read -rp "$prompt_term (y/n): " in_term
    read -rp "$prompt_comment: " in_comment

    [[ -z "$in_name" ]] && in_name="MyApp"
    [[ -z "$in_exec" ]] && in_exec="/usr/bin/example"
    [[ -z "$in_icon" ]] && in_icon="application-x-executable"
    [[ "$in_term" =~ ^[yY] ]] && in_term="true" || in_term="false"
    [[ -z "$in_comment" ]] && in_comment="Generated by deskgen"

    generate_template "$file" "$in_name" "$in_exec" "$in_icon" "$in_term" "$in_comment"
}

cmd_new() {
    [[ -z "$TARGET" ]] && { echo "[ERR] Usage: deskgen new <name>"; exit 1; }
    local file="$APP_DIR/$(add_ext "$TARGET")"
    [[ -f "$file" ]] && { echo "[WARN] File exists. Use 'edit' to modify."; exit 1; }
    
    if $INTERACTIVE; then
        interactive_wizard "$file"
    else
        generate_template "$file"
    fi
    
    # Try to update cache silently
    command -v update-desktop-database &>/dev/null && update-desktop-database "$APP_DIR" 2>/dev/null || true
}

cmd_ls() {
    echo -e "${C_YELLOW}📂 User Applications:${C_RESET}"
    local count=0
    for f in "$APP_DIR"/*.desktop; do
        [[ -f "$f" ]] && { echo "  $(basename "$f")"; ((count++)); }
    done
    [[ $count -eq 0 ]] && echo "  (none)"
}

cmd_rm() {
    [[ -z "$TARGET" ]] && { echo "[ERR] Usage: deskgen rm <name>"; exit 1; }
    local file="$APP_DIR/$(add_ext "$TARGET")"
    [[ ! -f "$file" ]] && { echo "[ERR] Not found: $file"; exit 1; }
    read -rp "Delete $(basename "$file")? [y/N] " ans
    [[ "${ans,,}" =~ ^y ]] && { rm -f "$file"; echo "[OK] Deleted."; command -v update-desktop-database &>/dev/null && update-desktop-database "$APP_DIR" 2>/dev/null || true; } || echo "[INFO] Cancelled."
}

cmd_edit() {
    [[ -z "$TARGET" ]] && { echo "[ERR] Usage: deskgen edit <name>"; exit 1; }
    local file="$APP_DIR/$(add_ext "$TARGET")"
    [[ ! -f "$file" ]] && { echo "[ERR] Not found. Create it first: deskgen new $TARGET"; exit 1; }
    ${EDITOR:-nano} "$file"
}

cmd_help() {
    cat <<EOF
${C_YELLOW}deskgen${C_RESET} - Lightweight .desktop file manager

${C_WHITE}Usage:${C_RESET}
  deskgen new <name>       Create new .desktop file
  deskgen ls               List all user .desktop files
  deskgen rm <name>        Delete a .desktop file
  deskgen edit <name>      Open in editor (\$EDITOR or nano)
  deskgen help             Show this help

${C_WHITE}Flags:${C_RESET}
  -i, --interactive        Guided creation wizard
  --lang ru|en             Comments language (default: en)

${C_WHITE}Examples:${C_RESET}
  deskgen new mytool
  deskgen new mytool -i --lang ru
  deskgen edit mytool
  deskgen rm mytool
EOF
}

# Route
case "${CMD:-help}" in
    new|start) cmd_new ;;
    ls) cmd_ls ;;
    rm|delete) cmd_rm ;;
    edit|nano) cmd_edit ;;
    help) cmd_help ;;
    *) cmd_help ;;
esac